      "source": [
        "import matplotlib.pyplot as plt\n",
        "from sklearn.datasets import load_breast_cancer\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.tree import DecisionTreeClassifier\n",
        "from sklearn.metrics import accuracy_score, classification_report\n",
        "from sklearn import tree\n"
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "Load data"
      ],
      "metadata": {
        "id": "g0DTqAAQDvrz"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "breast_cancer_wisconsin_diagnostic = load_breast_cancer()\n",
        "X = breast_cancer_wisconsin_diagnostic.data\n",
        "y = breast_cancer_wisconsin_diagnostic.target\n",
        "breast_cancer_wisconsin_diagnostic.target_names"
      ],
      "metadata": {
        "id": "r0TaWc13DrRC"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Preprocessing"
      ],
      "metadata": {
        "id": "pxZAPzBOEU1-"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=30)"
      ],
      "metadata": {
        "id": "eY95q70zEWym"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Model seslection and training"
      ],
      "metadata": {
        "id": "xVlppi7_EIaw"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "clf = DecisionTreeClassifier()\n",
        "clf.fit(X_train, y_train)\n",
        "train_accuracy = clf.score(X_train, y_train)\n",
        "print(train_accuracy)"
      ],
      "metadata": {
        "id": "jTREvEQZEKpW"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Model testing"
      ],
      "metadata": {
        "id": "G-WK1NGBD9du"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "y_pred = clf.predict(X_test)\n",
        "#Prediction 1\n",
        "print(y_pred[1])\n",
        "print(y_test[1])\n",
        "#Prediction 2\n",
        "print(y_pred[30])\n",
        "print(y_test[30])\n",
        "#Prediction 3\n",
        "print(y_pred[-1])\n",
        "print(y_test[-1])\n",
        "accuracy = accuracy_score(y_test, y_pred)\n",
        "print(\"Accuracy:\", accuracy)\n",
        "print(\"Classification Report:\\n\", classification_report(y_test, y_pred, target_names=breast_cancer_wisconsin_diagnostic.target_names))\n"
      ],
      "metadata": {
        "id": "LyKeInp4D8S5"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
